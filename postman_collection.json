    {
      "name": "2. Driver Mileage API (The Masking Twist)",
      "item": [
        {
          "name": "2a. View Mileage logs (Role-Based Access)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://127.0.0.1:8000/api/mileage/",
              "protocol": "http",
              "host": [
                "127.0.0.1"
              ],
              "port": "8000",
              "path": [
                "api",
                "mileage",
                ""
              ]
            }
          },
          "response": []
        },
